{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "architect-output",
  "title": "Architect Agent Output",
  "description": "The structured payload Architect emits after wiring components into the app.",
  "type": "object",
  "required": ["traceId", "agentVersion", "pages", "buildStatus", "handoff"],
  "properties": {
    "traceId":      { "type": "string" },
    "agentVersion": { "type": "string" },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "component", "sections"],
        "properties": {
          "route":     { "type": "string", "example": "/" },
          "component": { "type": "string", "example": "src/pages/Home.tsx" },
          "sections":  { "type": "array", "items": { "type": "string" } },
          "seoReady":  { "type": "boolean" },
          "i18nReady": { "type": "boolean" }
        }
      }
    },
    "providers": { "type": "array", "items": { "type": "string" }, "example": ["ChakraProvider", "QueryClientProvider"] },
    "devServer":   { "type": "string", "example": "http://localhost:3001" },
    "buildStatus": { "type": "string", "enum": ["pass", "fail", "skip"] },
    "typeErrors":  { "type": "integer" },
    "consoleWarnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "object" } },
    "handoff": { "type": "string", "enum": ["test", "a11y", "perf", "seo", "docs", "human"] }
  }
}
