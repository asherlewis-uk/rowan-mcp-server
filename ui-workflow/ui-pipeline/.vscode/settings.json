{
  "mcp.servers": {
    "stitch": {
      "command": "npx",
      "args": ["-y", "stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${env:STITCH_API_KEY}"
      }
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${env:MAGIC_API_KEY}"
      }
    },
    "nano-banana": {
      "command": "npx",
      "args": ["-y", "nano-banana-mcp"],
      "env": {
        "NANO_BANANA_API_KEY": "${env:NANO_BANANA_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  },
  "mcp.serverRouting": "./mcp/routing.yaml",
  "editor.formatOnSave": true,
  "typescript.tsdk": "node_modules/typescript/lib"
}
