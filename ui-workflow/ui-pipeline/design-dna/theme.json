{
  "colors": {
    "brand": {
      "50":  "#fff0f0",
      "100": "#ffd6d6",
      "200": "#ffadad",
      "300": "#ff8585",
      "400": "#ff7070",
      "500": "#ff6b6b",
      "600": "#d94f4f",
      "700": "#b33030",
      "800": "#8c1c1c",
      "900": "#5e0a0a"
    },
    "neutral": {
      "0":   "#ffffff",
      "50":  "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
