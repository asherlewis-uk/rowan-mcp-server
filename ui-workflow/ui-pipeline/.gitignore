# Dependencies
node_modules/

# Build output
dist/

# Local env files — never commit keys
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
# Keep .vscode/settings.json and .cursor/mcp.json out of git — they use ${env:VAR}
# templates above; devs supply real keys via .env or shell env.
# Uncomment the lines below if you prefer to gitignore them entirely:
# .vscode/settings.json
# .cursor/

# Logs
*.log
npm-debug.log*
